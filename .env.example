# Copy this to .env for local development:  cp .env.example .env
# The defaults below point at a local Ollama server — no API key needed.
# On a Hugging Face Space this file is unused: set these as Space Variables
# and set GROQ_API_KEY as a Space *Secret* instead.

# --- LLM backend (any OpenAI-compatible endpoint) ---
# Local dev  -> Ollama:  http://localhost:11434/v1   (run `ollama serve`)
# Hosted demo -> Groq:   https://api.groq.com/openai/v1
LLM_BASE_URL=http://localhost:11434/v1

# Local  -> a pulled Ollama model, e.g. llama3.2
# Groq   -> a Groq model id, e.g. llama-3.3-70b-versatile
LLM_MODEL=llama3.2

# API key. Ollama ignores it, so leave the placeholder for local dev.
# For Groq, prefer the GROQ_API_KEY name (matches the Space Secret) — the app
# reads LLM_API_KEY first, then GROQ_API_KEY, then falls back to "ollama".
LLM_API_KEY=ollama
# GROQ_API_KEY=gsk_...

# --- Retrieval knobs (safe to tune while learning) ---
CHUNK_SIZE=1000        # characters per passage
CHUNK_OVERLAP=150      # overlap so facts spanning a boundary aren't cut in half
TOP_K=4                # how many chunks to retrieve per question
